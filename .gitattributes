# ── Phone‑first Git safety ──────────────────
# Force consistent line endings and prevent
# file‑mode & encoding corruption on Android.

# Default: auto‑detect text files, use LF
*       text=auto

# Explicitly mark source code as text
*.py    text
*.md    text
*.txt   text
*.json  text
*.yml   text
*.yaml  text
*.toml  text

# Binary files – never touch line endings
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.apk   binary
*.ttf   binary
*.woff  binary
*.woff2 binary

# Keep shell scripts with LF only
*.sh    text eol=lf

# Windows batch files (rare on phone, safe to include)
*.bat   text eol=crlf