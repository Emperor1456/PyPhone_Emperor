# ── Phone‑first Git safety ──────────────────
*       text=auto

# Source code
*.py    text
*.md    text
*.txt   text
*.json  text
*.yml   text
*.yaml  text
*.toml  text

# Data files (track as text if they are human‑readable)
*.csv   text
*.log   text

# Binary files – never touch line endings
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.apk   binary
*.ttf   binary
*.woff  binary
*.woff2 binary

# SQLite databases are binary
*.db    binary

# Shell scripts – LF only
*.sh    text eol=lf

# Windows batch files (rare)
*.bat   text eol=crlf